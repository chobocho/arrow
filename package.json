{
  "name": "arrow-mindmap",
  "version": "0.1.0",
  "private": true,
  "description": "Arrow-only mindmap — HTML5 Canvas, TypeScript, single-file release.",
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:bundle": "node scripts/build.mjs --no-inline",
    "build:min": "node scripts/build.mjs --minify",
    "test": "node scripts/build.mjs --no-inline && node test/run_node.js",
    "typecheck": "tsc --noEmit -p tsconfig.json --ignoreDeprecations 6.0",
    "watch": "esbuild src/index.ts --bundle --format=iife --target=es2019 --outfile=dist/bundle.js --global-name=ArrowApp --watch"
  },
  "devDependencies": {
    "esbuild": "^0.23.0",
    "esbuild-wasm": "^0.23.0",
    "typescript": "^5.4.0"
  }
}
